{
  "manifest_version": 3,
  "name": "PromptBooks - The Digital Archivist",
  "version": "1.0.0",
  "description": "儲存、管理並快速取用常用的 AI 提示詞",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open PromptBooks"
  }
}
